# Gradle
.gradle/
build/

# Kotlin
.kotlin/

# IDE / tooling
.idea/
*.iml
# Ignore local Claude Code config (settings.local.json etc.), but keep committed skills —
# e.g. .claude/skills/jts-rebase, the workflow for re-basing this port onto a newer JTS release.
.claude/*
!.claude/skills/

# Build / run output
*.class
*.log
hs_err_pid*

# JARs are build output — but the Gradle wrapper jar MUST be committed so `gradlew` works.
*.jar
!gradle/wrapper/gradle-wrapper.jar

# OS
.DS_Store

# Note: kotlin-js-store/yarn.lock is intentionally committed (reproducible JS/Wasm builds).
